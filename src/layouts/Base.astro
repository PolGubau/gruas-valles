---
import { Font } from "astro:assets";
import SEO from "../components/seo/SEO.astro";
import FloatCTA from "../components/ui/FloatCTA.astro";
import MobileBar from "../components/ui/MobileBar.astro";
import WhatsAppFAB from "../components/ui/WhatsAppFAB.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: object | object[];
}

const {
  title = "Grúas del Vallès | Alquiler de Grúas Industriales en Barcelona",
  description = "Empresa líder en alquiler de grúas móviles autopropulsadas de 40 a 700 Tn en Cataluña. +55 años de experiencia. Servicio de emergencia 24/365.",
  image = "/og-image.avif",
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#d60b0c" />
    <meta name="generator" content={Astro.generator} />

    <!-- Enable scroll-reveal only when scripting is available -->
    <script is:inline>
      document.documentElement.classList.add("reveal");
    </script>

    <SEO
      title={title}
      description={description}
      image={image}
      schema={schema}
    />

    <!-- Plus Jakarta Sans - self-hosted via Astro experimental fonts -->
    <Font cssVariable="--font-jakarta" preload />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-100 focus:bg-accent focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-white"
    >
      Saltar al contenido
    </a>
    <slot />
    <FloatCTA />
    <MobileBar />
    <WhatsAppFAB />

    <script>
      // Reveal elements as they enter the viewport (one-shot per element).
      const items = document.querySelectorAll<HTMLElement>("[data-reveal]");
      if (items.length && "IntersectionObserver" in window) {
        const io = new IntersectionObserver(
          (entries, observer) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) continue;
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          },
          { rootMargin: "0px 0px -10% 0px", threshold: 0.1 },
        );
        items.forEach((el) => io.observe(el));
      } else {
        items.forEach((el) => el.classList.add("is-visible"));
      }
    </script>

    <script>
      // Zoom de imágenes (lightbox ligero) para cualquier <img data-zoomable>.
      import mediumZoom from "medium-zoom";
      mediumZoom("[data-zoomable]", {
        margin: 24,
        background: "rgb(18 18 18 / 0.92)",
      });
    </script>
  </body>
</html>
