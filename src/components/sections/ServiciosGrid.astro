---
import { Icon } from "astro-icon/components";
import servicios from "../../data/servicios.json";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";

interface Props {
  /** En la landing (preview) dejamos solo las categorías destacadas en móvil
   *  y enlazamos a /servicios; en la página dedicada se muestra todo. */
  preview?: boolean;
}

const { preview = false } = Astro.props;

const iconos: string[] = [
  "lucide:building-2",
  "lucide:truck",
  "lucide:zap",
  "lucide:package",
  "lucide:users",
  "lucide:shield-check",
  "lucide:building",
  "lucide:clock",
  "lucide:map-pin",
];
---

<Section
  id="servicios"
  bg="white"
  title="Todo lo que necesitas en una sola empresa"
>
  <!-- Departamento de estudios · servicio destacado -->
  <a
    href="/servicios/ingenieria-de-maniobra"
    class="group relative mb-10 flex flex-col gap-6 overflow-hidden bg-ink p-8 text-white transition-all hover:shadow-xl sm:p-12 lg:flex-row lg:items-center lg:justify-between lg:gap-12"
    data-reveal
  >
    <div class="max-w-3xl">
      <p
        class="mb-3 text-xs font-semibold uppercase tracking-wider text-accent"
      >
        Departamento de estudios
      </p>
      <h3 class="mb-4 text-2xl font-black leading-tight sm:text-4xl">
        Ingeniería antes de la maniobra
      </h3>
      <p class="text-sm leading-relaxed text-muted sm:text-base">
        {servicios.departamento_de_estudios}
      </p>
    </div>
    <span
      class="inline-flex shrink-0 items-center gap-2 text-[11px] font-bold uppercase tracking-widest text-accent"
    >
      Ver detalles
      <Icon
        name="lucide:move-right"
        class="h-4 w-4 transition-transform group-hover:translate-x-1"
      />
    </span>
  </a>

  <!-- Featured Categories -->
  <div class="mb-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      servicios.categorias
        .filter((cat: any) => cat.slug !== "ingenieria-de-maniobra")
        .map((cat: any) => (
          <a
            href={`/servicios/${cat.slug}`}
            class="group relative flex flex-col bg-surface-alt p-6 transition-all hover:bg-white hover:shadow-xl sm:p-8"
          >
            <div class="mb-6 flex h-12 w-12 items-center justify-center bg-white text-accent shadow-sm group-hover:bg-accent group-hover:text-white transition-colors">
              <Icon name="lucide:arrow-up-right" class="h-6 w-6" />
            </div>
            <h3 class="mb-3 text-lg font-black leading-tight group-hover:text-accent transition-colors">
              {cat.titulo}
            </h3>
            <p class="text-xs leading-relaxed text-ink-secondary line-clamp-3">
              {cat.descripcion}
            </p>
            <span class="mt-6 flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-accent">
              Ver detalles{" "}
              <Icon
                name="lucide:move-right"
                class="h-3 w-3 transition-transform group-hover:translate-x-1"
              />
            </span>
          </a>
        ))
    }
  </div>

  <!-- En la landing, este bloque secundario se colapsa en móvil (ver /servicios) -->
  <div
    class:list={["mb-8 flex items-center gap-4", { "max-sm:hidden": preview }]}
  >
    <div class="h-px flex-1 bg-muted"></div>
    <span class="text-[10px] font-bold uppercase tracking-wider text-muted-dark"
      >Otros servicios especializados</span
    >
    <div class="h-px flex-1 bg-muted"></div>
  </div>

  <!-- Grid de servicios principales -->
  <div
    class:list={[
      "grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3",
      { "max-sm:hidden": preview },
    ]}
    data-reveal
  >
    {
      servicios.principales.map((servicio: string, i: number) => (
        <div class="group flex items-start gap-4 border-t-2 border-transparent bg-white p-5 transition-colors duration-200 hover:border-accent hover:bg-surface-alt sm:p-6">
          <Icon
            name={iconos[i] ?? iconos[0]}
            class="h-6 w-6 shrink-0 text-accent"
            aria-hidden="true"
          />
          <p class="text-sm font-medium leading-snug text-ink">{servicio}</p>
        </div>
      ))
    }
  </div>

  <!-- CTA solo en móvil y solo en la landing: el detalle completo está en /servicios -->
  {
    preview && (
      <div class="mt-10 text-center sm:hidden">
        <Button
          href="/servicios"
          variant="outline"
          size="sm"
          icon="lucide:arrow-right"
        >
          Ver todos los servicios
        </Button>
      </div>
    )
  }
</Section>
