---
import { getCollection } from "astro:content";
import { resolveImage } from "../../lib/images";
import FlotaCard from "../flota/FlotaCard.astro";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";

// Fuente única: colección «flota» (ver src/content.config.ts)
const entries = await getCollection("flota");
const allModels = entries
  .map((e) => ({ slug: e.id, ...e.data }))
  .sort((a, b) => a.orden - b.orden);

const categorias = [...new Set(allModels.map((m) => m.categoria))];
const newModels = allModels.filter((m) => m.nuevo);
---

<Section id="flota" bg="alt" title="Maquinaria para cualquier maniobra">
  <p slot="intro">
    28 grúas propias — industriales y móviles autopropulsadas — siempre
    actualizadas. Si necesita una configuración específica,
    <a href="#contacto" class="font-medium text-accent underline">consúltenos</a
    >.
  </p>

  <!-- ── Novedades ── -->
  {
    newModels.length > 0 && (
      <div class="novedades-wrapper mb-16" data-reveal>
        {/* Eyebrow label */}
        <div class="novedades-label-row">
          <div class="novedades-eyebrow">
            <span class="novedades-dot" aria-hidden="true" />
            Nuevas incorporaciones
          </div>
          <a href="/flota" class="novedades-link">
            Ver toda la flota →
          </a>
        </div>

        {/* Tarjetas landscape */}
        <div class="novedades-list">
          {newModels.map((model) => {
            const capacidad = model.capacidad_max_t ?? model.capacidad_tm;
            return (
              <a href={`/flota/${model.slug}`} class="novedades-card group">
                <div class="novedades-img">
                  {model.imagenes.length > 0 ? (
                    <img
                      src={resolveImage(model.imagenes[0])}
                      alt={model.modelo}
                      class="h-full w-full object-contain p-6 transition-transform duration-500 group-hover:scale-[1.04]"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : null}
                </div>
                <div class="novedades-content">
                  <span class="novedades-tag">Nueva adquisición</span>
                  <h4 class="novedades-card-title">{model.modelo}</h4>
                  {capacidad && (
                    <p class="novedades-cap">
                      {capacidad}
                      <span> Tn</span>
                    </p>
                  )}
                  {model.nota && <p class="novedades-nota">{model.nota}</p>}
                  <span class="novedades-cta">
                    Ver ficha técnica
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                      class="novedades-cta-arrow"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )
  }

  <!-- Filtros (ocultos en móvil: la selección destacada va sin filtrar y el catálogo completo está en /flota) -->
  <div
    class="mb-8 flex flex-wrap gap-2 max-sm:hidden"
    id="flota-filters"
    role="group"
    aria-label="Filtrar flota por categoría"
  >
    <button
      type="button"
      data-filter="all"
      aria-pressed="true"
      class="filter-btn active-filter text-xs font-semibold uppercase tracking-wider px-4 py-2 border-2 border-accent bg-accent text-white transition-colors"
    >
      Todas
    </button>
    {
      categorias.map((cat) => (
        <button
          type="button"
          data-filter={cat}
          aria-pressed="false"
          class="filter-btn text-xs font-semibold uppercase tracking-wider px-4 py-2 border-2 border-muted text-ink-secondary transition-colors hover:border-accent hover:text-accent"
        >
          {cat}
        </button>
      ))
    }
  </div>

  <!-- Grid -->
  <!-- En móvil mostramos solo una selección; el resto se ve desde sm o en /flota -->
  <div
    class="grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3"
    id="flota-grid"
  >
    {allModels.slice(0, 3).map((model) => <FlotaCard model={model} />)}
    <div class="contents max-sm:hidden">
      {allModels.slice(3, 6).map((model) => <FlotaCard model={model} />)}
    </div>
  </div>

  <!-- CTA bottom -->
  <div class="mt-12 flex flex-wrap justify-center gap-4">
    <Button href="/flota" variant="outline" icon="lucide:list">
      Ver toda la flota
    </Button>
    <Button href="#contacto" icon="lucide:arrow-right">
      Consultar disponibilidad
    </Button>
  </div>
</Section>

<style>
  /* ── Eyebrow row ── */
  .novedades-label-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .novedades-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .novedades-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.35;
      transform: scale(0.65);
    }
  }

  .novedades-link {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink-secondary);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .novedades-link:hover {
    color: var(--color-accent);
  }

  /* ── Lista de tarjetas ── */
  .novedades-list {
    display: flex;
    flex-direction: column;
    gap: 1px;
    background: var(--color-muted);
  }

  /* ── Tarjeta landscape ── */
  .novedades-card {
    display: grid;
    grid-template-columns: 1fr;
    background: white;
    text-decoration: none;
    color: inherit;
    border-top: 3px solid var(--color-accent);
    transition: background 0.25s;
    position: relative;
  }

  @media (min-width: 640px) {
    .novedades-card {
      grid-template-columns: 2fr 3fr;
    }
  }

  .novedades-card:hover {
    background: color-mix(in srgb, var(--color-accent) 3%, white);
  }

  /* Imagen */
  .novedades-img {
    background: var(--color-surface-alt);
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .novedades-img {
      aspect-ratio: auto;
      min-height: 220px;
    }
  }

  /* Contenido */
  .novedades-content {
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.6rem;
    border-left: none;
  }

  @media (min-width: 640px) {
    .novedades-content {
      border-left: 1px solid rgb(0 0 0 / 0.07);
    }
  }

  .novedades-tag {
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .novedades-card-title {
    font-size: 1.4rem;
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
    color: var(--color-ink);
    transition: color 0.2s;
  }

  @media (min-width: 1024px) {
    .novedades-card-title {
      font-size: 1.75rem;
    }
  }

  .novedades-card:hover .novedades-card-title {
    color: var(--color-accent);
  }

  .novedades-cap {
    font-size: 2.25rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0.1rem 0 0;
  }

  .novedades-cap span {
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0;
    color: var(--color-ink-secondary);
  }

  .novedades-nota {
    font-size: 0.8rem;
    font-style: italic;
    color: var(--color-ink-secondary);
    line-height: 1.5;
    margin: 0;
  }

  .novedades-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    transition: gap 0.25s;
  }

  .novedades-cta-arrow {
    transition: transform 0.25s
      var(--ease-out-quart, cubic-bezier(0.25, 1, 0.5, 1));
  }

  .novedades-card:hover .novedades-cta {
    gap: 0.65rem;
  }

  .novedades-card:hover .novedades-cta-arrow {
    transform: translateX(0.2rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .novedades-dot,
    .novedades-cta-arrow,
    .novedades-card {
      animation: none;
      transition: none;
    }
  }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".flota-card");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      filters.forEach((b) => {
        b.classList.remove(
          "active-filter",
          "bg-accent",
          "text-white",
          "border-accent",
        );
        b.classList.add("border-muted", "text-ink-secondary");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add(
        "active-filter",
        "bg-accent",
        "text-white",
        "border-accent",
      );
      btn.classList.remove("border-muted", "text-ink-secondary");
      btn.setAttribute("aria-pressed", "true");

      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.categoria === filter;
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>
