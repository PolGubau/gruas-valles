---
import { getCollection } from "astro:content";
import { resolveImage } from "../../lib/images";
import FlotaCard from "../flota/FlotaCard.astro";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";

// Fuente única: colección «flota» (ver src/content.config.ts)
const entries = await getCollection("flota");
const allModels = entries
  .map((e) => ({ slug: e.id, ...e.data }))
  .sort((a, b) => a.orden - b.orden);

const categorias = [...new Set(allModels.map((m) => m.categoria))];
const newModels = allModels.filter((m) => m.nuevo);
---

<Section id="flota" bg="alt" title="Maquinaria para cualquier maniobra">
  <p slot="intro">
    28 grúas propias — industriales y móviles autopropulsadas — siempre
    actualizadas. Si necesita una configuración específica,
    <a href="#contacto" class="font-medium text-accent underline">consúltenos</a
    >.
  </p>

  <!-- ── Novedades ── -->
  {
    newModels.length > 0 && (
      <div class="novedades-wrapper mb-16" data-reveal>
        {/* Cabecera de la sección */}
        <div class="novedades-header">
          <div class="novedades-header-inner">
            <div class="novedades-badge">
              <span class="novedades-badge-dot" aria-hidden="true" />
              Nuevo
            </div>
            <div>
              <h3 class="novedades-title">Nuevas incorporaciones</h3>
              <p class="novedades-subtitle">
                Las últimas adquisiciones a nuestra flota
              </p>
            </div>
          </div>
          <a href="/flota" class="novedades-link">
            Ver toda la flota →
          </a>
        </div>

        {/* Tarjetas */}
        <div class="novedades-track">
          {newModels.map((model) => {
            const capacidad = model.capacidad_max_t ?? model.capacidad_tm;
            return (
              <a href={`/flota/${model.slug}`} class="novedades-card group">
                <div class="novedades-img">
                  {model.imagenes.length > 0 ? (
                    <img
                      src={resolveImage(model.imagenes[0])}
                      alt={model.modelo}
                      class="h-full w-full object-contain p-4 transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                      decoding="async"
                    />
                  ) : null}
                  <span class="novedades-card-badge">Nueva</span>
                </div>
                <div class="novedades-card-body">
                  <h4 class="novedades-card-title group-hover:text-accent">
                    {model.modelo}
                  </h4>
                  {capacidad && (
                    <p class="novedades-card-cap">{capacidad} Tn</p>
                  )}
                  {model.nota && (
                    <p class="novedades-card-nota">{model.nota}</p>
                  )}
                  <span class="novedades-card-cta">Ver ficha técnica →</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    )
  }

  <!-- Filtros (ocultos en móvil: la selección destacada va sin filtrar y el catálogo completo está en /flota) -->
  <div
    class="mb-8 flex flex-wrap gap-2 max-sm:hidden"
    id="flota-filters"
    role="group"
    aria-label="Filtrar flota por categoría"
  >
    <button
      type="button"
      data-filter="all"
      aria-pressed="true"
      class="filter-btn active-filter text-xs font-semibold uppercase tracking-wider px-4 py-2 border-2 border-accent bg-accent text-white transition-colors"
    >
      Todas
    </button>
    {
      categorias.map((cat) => (
        <button
          type="button"
          data-filter={cat}
          aria-pressed="false"
          class="filter-btn text-xs font-semibold uppercase tracking-wider px-4 py-2 border-2 border-muted text-ink-secondary transition-colors hover:border-accent hover:text-accent"
        >
          {cat}
        </button>
      ))
    }
  </div>

  <!-- Grid -->
  <!-- En móvil mostramos solo una selección; el resto se ve desde sm o en /flota -->
  <div
    class="grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3"
    id="flota-grid"
  >
    {allModels.slice(0, 3).map((model) => <FlotaCard model={model} />)}
    <div class="contents max-sm:hidden">
      {allModels.slice(3, 6).map((model) => <FlotaCard model={model} />)}
    </div>
  </div>

  <!-- CTA bottom -->
  <div class="mt-12 flex flex-wrap justify-center gap-4">
    <Button href="/flota" variant="outline" icon="lucide:list">
      Ver toda la flota
    </Button>
    <Button href="#contacto" icon="lucide:arrow-right">
      Consultar disponibilidad
    </Button>
  </div>
</Section>

<style>
  /* ── Wrapper: borde accent izquierdo + fondo ligeramente diferenciado ── */
  .novedades-wrapper {
    border-left: 4px solid var(--color-accent);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-accent) 6%, transparent) 0%,
      transparent 60%
    );
    border-radius: 0 8px 8px 0;
    overflow: hidden;
  }

  /* ── Cabecera oscura tipo "banner" ── */
  .novedades-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    background: var(--color-ink, #111);
    padding: 1.25rem 1.5rem;
  }

  .novedades-header-inner {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* Badge "Nuevo" con punto pulsante */
  .novedades-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: white;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.35rem 0.75rem;
    border-radius: 2px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .novedades-badge-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: white;
    animation: pulse-dot 1.8s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.4;
      transform: scale(0.7);
    }
  }

  .novedades-title {
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.2;
    color: white;
    margin: 0;
    letter-spacing: -0.01em;
  }

  @media (min-width: 640px) {
    .novedades-title {
      font-size: 1.5rem;
    }
  }

  .novedades-subtitle {
    font-size: 0.75rem;
    color: rgb(255 255 255 / 0.5);
    margin: 0.15rem 0 0;
  }

  .novedades-link {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s;
  }
  .novedades-link:hover {
    opacity: 0.75;
  }

  /* ── Track de tarjetas ── */
  .novedades-track {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 1.5rem;
    -webkit-mask-image: linear-gradient(to right, #000 88%, transparent 100%);
    mask-image: linear-gradient(to right, #000 88%, transparent 100%);
  }

  .novedades-track::-webkit-scrollbar {
    height: 3px;
  }
  .novedades-track::-webkit-scrollbar-track {
    background: transparent;
  }
  .novedades-track::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: 2px;
  }

  /* ── Tarjeta individual ── */
  .novedades-card {
    flex-shrink: 0;
    width: 20rem;
    scroll-snap-align: start;
    background: white;
    border-radius: 4px;
    overflow: hidden;
    box-shadow:
      0 2px 8px -2px rgb(0 0 0 / 0.1),
      0 0 0 1px rgb(0 0 0 / 0.05);
    text-decoration: none;
    color: inherit;
    transition:
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .novedades-card:hover {
    box-shadow:
      0 12px 32px -6px rgb(0 0 0 / 0.18),
      0 0 0 2px var(--color-accent);
    transform: translateY(-3px);
  }

  /* Imagen con badge superpuesto */
  .novedades-img {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface-alt, #f4f4f5);
  }

  /* Badge "Nueva" encima de la imagen */
  .novedades-card-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: var(--color-accent);
    color: white;
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
  }

  .novedades-card-body {
    padding: 1rem 1.25rem 1.25rem;
    border-top: 2px solid var(--color-accent);
  }

  .novedades-card-title {
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.3;
    transition: color 0.2s;
    margin: 0 0 0.25rem;
  }

  .novedades-card-cap {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: 0;
  }

  .novedades-card-nota {
    font-size: 0.7rem;
    font-style: italic;
    color: var(--color-ink-secondary, #666);
    margin: 0.35rem 0 0;
    line-height: 1.4;
  }

  .novedades-card-cta {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .novedades-card,
    .novedades-badge-dot {
      transition: none;
      animation: none;
    }
  }
</style>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const cards = document.querySelectorAll<HTMLElement>(".flota-card");

  filters.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter!;

      filters.forEach((b) => {
        b.classList.remove(
          "active-filter",
          "bg-accent",
          "text-white",
          "border-accent",
        );
        b.classList.add("border-muted", "text-ink-secondary");
        b.setAttribute("aria-pressed", "false");
      });
      btn.classList.add(
        "active-filter",
        "bg-accent",
        "text-white",
        "border-accent",
      );
      btn.classList.remove("border-muted", "text-ink-secondary");
      btn.setAttribute("aria-pressed", "true");

      cards.forEach((card) => {
        const show = filter === "all" || card.dataset.categoria === filter;
        card.style.display = show ? "" : "none";
      });
    });
  });
</script>
