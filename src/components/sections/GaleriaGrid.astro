---
import galerias from "../../data/galerias.json";
import { resolveImages } from "../../lib/images";
import Button from "../ui/Button.astro";
import Section from "../ui/Section.astro";

interface Props {
  /** En la landing (preview) recortamos en móvil y enlazamos a /galeria;
   *  en la página dedicada se muestra todo, con sus pestañas. */
  preview?: boolean;
}

const { preview = false } = Astro.props;

// En móvil (solo en preview) mostramos una muestra por categoría; el resto en /galeria.
const VISIBLE_ON_MOBILE = 6;

const cats = (galerias as Array<{ categoria: string; imagenes: string[] }>).map(
  (cat) => ({ ...cat, imagenes: resolveImages(cat.imagenes) }),
);
---

<Section id="galeria" bg="white" title="Imágenes de nuestros proyectos reales">
  <!-- Tabs de categoría (en la landing se ocultan en móvil; viven en /galeria) -->
  <div
    class:list={["mb-8 flex flex-wrap gap-2", { "max-sm:hidden": preview }]}
    id="gal-tabs"
    role="tablist"
    aria-label="Categorías de la galería"
  >
    {
      cats.map((cat, i) => (
        <button
          type="button"
          role="tab"
          id={`gal-tab-${i}`}
          data-tab={i}
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`gal-panel-${i}`}
          class={`gal-tab text-xs font-semibold uppercase tracking-wider px-4 py-2 border-2 transition-colors ${i === 0 ? "border-accent bg-accent text-white" : "border-muted text-ink-secondary hover:border-accent hover:text-accent"}`}
        >
          {cat.categoria}
        </button>
      ))
    }
  </div>

  <!-- Grid por categoría -->
  {
    cats.map((cat, i) => (
      <div
        id={`gal-panel-${i}`}
        role="tabpanel"
        aria-labelledby={`gal-tab-${i}`}
        data-panel={i}
        class={`gal-panel ${i !== 0 ? "hidden" : ""}`}
      >
        <div class="columns-2 gap-px sm:columns-3 lg:columns-4">
          {cat.imagenes.slice(0, 16).map((img: string, j: number) => (
            <div
              class:list={[
                "mb-px overflow-hidden break-inside-avoid bg-surface-alt",
                { "max-sm:hidden": preview && j >= VISIBLE_ON_MOBILE },
              ]}
            >
              <img
                src={img}
                alt={`${cat.categoria} - foto ${j + 1}`}
                class="w-full cursor-zoom-in object-cover transition-transform duration-500 hover:scale-105"
                loading="lazy"
                decoding="async"
                data-zoomable
              />
            </div>
          ))}
        </div>
        {cat.imagenes.length > 16 && (
          <p class="mt-4 text-center text-xs text-muted-dark">
            +{cat.imagenes.length - 16} fotos más.{" "}
            <a href="#contacto" class="text-accent underline">
              Contáctenos para el portfolio completo.
            </a>
          </p>
        )}
      </div>
    ))
  }

  <!-- CTA solo en móvil y solo en la landing: el resto de imágenes está en /galeria -->
  {
    preview && (
      <div class="mt-8 text-center sm:hidden">
        <Button
          href="/galeria"
          variant="outline"
          size="sm"
          icon="lucide:arrow-right"
        >
          Ver galería completa
        </Button>
      </div>
    )
  }
</Section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".gal-tab");
  const panels = document.querySelectorAll<HTMLElement>(".gal-panel");

  tabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      const idx = tab.dataset.tab!;

      tabs.forEach((t) => {
        t.classList.remove("border-accent", "bg-accent", "text-white");
        t.classList.add("border-muted", "text-ink-secondary");
        t.setAttribute("aria-selected", "false");
      });
      tab.classList.add("border-accent", "bg-accent", "text-white");
      tab.classList.remove("border-muted", "text-ink-secondary");
      tab.setAttribute("aria-selected", "true");

      panels.forEach((p) => {
        p.classList.toggle("hidden", p.dataset.panel !== idx);
      });
    });
  });
</script>
