---
import { catalogo } from "../../lib/docs";
import { resolveImage } from "../../lib/images";
import Button from "../ui/Button.astro";

// ── SLIDESHOW DE HERO ─────────────────────────────────────────────────────────
// Para cambiar fotos: añade o elimina objetos de este array.
// Segundos entre cambios: ajusta SLIDE_INTERVAL.
const SLIDE_INTERVAL = 6; // segundos

const heroSlides = [
  {
    src: "/assets/images/hero-grua-accion-2024-01.avif",
    alt: "Grúa Liebherr LTM 1100 de Grúas del Vallès en operación",
  },
  // { src: "/assets/images/hero-foto-2.avif", alt: "..." },
  // { src: "/assets/images/hero-foto-3.avif", alt: "..." },
];

const slides = heroSlides.map((s) => ({ ...s, src: resolveImage(s.src) }));
// ─────────────────────────────────────────────────────────────────────────────
---

<section
  id="hero"
  class="relative flex min-h-svh flex-col justify-end overflow-hidden bg-ink pt-16"
>
  <!-- Slideshow de fondo -->
  <div
    id="hero-slideshow"
    class="absolute inset-0 overflow-hidden"
    data-interval={SLIDE_INTERVAL}
  >
    {
      slides.map((slide, i) => (
        <img
          src={slide.src}
          alt={slide.alt}
          class={`hero-slide absolute inset-0 h-full w-full object-cover object-center${i === 0 ? " is-active" : ""}`}
          fetchpriority={i === 0 ? "high" : "low"}
          loading={i === 0 ? "eager" : "lazy"}
          decoding="async"
        />
      ))
    }
    <!-- Gradient overlay -->
    <div
      class="absolute inset-0 bg-linear-to-t from-ink via-ink/85 to-ink/30 sm:via-ink/60 sm:to-transparent"
    >
    </div>
    <!-- Vignette -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(125% 110% at 30% 10%, transparent 50%, rgb(10 10 10 / 0.6) 100%);"
    >
    </div>
    <!-- Red accent line top -->
    <div class="absolute top-16 left-0 h-1 w-24 bg-accent"></div>
  </div>

  <!-- Content -->
  <div class="container-wide relative z-10 section-padding pb-10 sm:pb-14">
    <div class="max-w-4xl">
      <!-- Headline -->
      <h1
        class="mb-5 text-[clamp(1.9rem,6.5vw,5rem)] font-black leading-[0.92] tracking-tight text-white sm:mb-6"
        data-reveal
        data-reveal-delay="1"
      >
        Servicios de grúas<br />
        <span class="text-accent">autopropulsadas</span><br />
        <span class="text-white/80">hasta 700 Tn</span>
      </h1>

      <!-- Subheadline -->
      <p
        class="mb-8 max-w-md text-base leading-relaxed text-white/60 sm:mb-10 sm:max-w-xl sm:text-lg sm:text-muted"
        data-reveal
        data-reveal-delay="2"
      >
        86 vehículos propios en Cataluña · hasta 700&nbsp;Tn<br /> Servicio de emergencia
        <strong class="text-white/90 sm:text-white">24 h · 365 días</strong>
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-4"
        data-reveal
        data-reveal-delay="3"
      >
        <Button
          href="#contacto"
          icon="lucide:arrow-right"
          class="w-full sm:w-auto"
        >
          Solicitar presupuesto
        </Button>
        <Button
          href="tel:+34938497022"
          variant="outline"
          icon="lucide:phone"
          iconPosition="start"
          class="hidden border-white text-white hover:bg-white hover:text-ink! sm:inline-flex sm:w-auto"
        >
          93 849 70 22
        </Button>
        <Button
          href={catalogo.url}
          download={catalogo.filename}
          variant="ghost"
          icon="lucide:download"
          iconPosition="start"
          class="hidden text-white hover:text-accent sm:inline-flex sm:w-auto"
        >
          {catalogo.label}
        </Button>
      </div>
    </div>
  </div>

  <!-- Stats band — full width, anchored to bottom of hero -->
  <dl class="relative z-10 grid grid-cols-4 gap-px bg-white/10">
    {
      [
        { value: "+55", label: "Años de experiencia" },
        { value: "86", label: "Vehículos propios" },
        { value: "28", label: "Grúas propias" },
        { value: "700 Tn", label: "Capacidad máx." },
      ].map(({ value, label }) => (
        <div class="border-t-2 border-accent bg-black/50 px-4 py-5 backdrop-blur-sm sm:px-8 sm:py-6">
          <dt class="sr-only">{label}</dt>
          <dd>
            <span class="block text-2xl font-black leading-none tracking-tight text-white sm:text-3xl">
              {value}
            </span>
            <span class="mt-1.5 block text-[11px] uppercase tracking-wider text-white/50 sm:text-xs">
              {label}
            </span>
          </dd>
        </div>
      ))
    }
  </dl>
</section>

<style>
  .hero-slide {
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }
  .hero-slide.is-active {
    opacity: 0.4;
  }
  @media (min-width: 640px) {
    .hero-slide.is-active {
      opacity: 0.6;
    }
  }
</style>

<script>
  const container = document.getElementById("hero-slideshow");
  const slides = container?.querySelectorAll<HTMLElement>(".hero-slide");
  const interval = Number(container?.dataset.interval ?? 6) * 1000;

  if (slides && slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove("is-active");
      current = (current + 1) % slides.length;
      slides[current].classList.add("is-active");
    }, interval);
  }
</script>
