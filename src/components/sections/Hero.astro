---
import { catalogo } from "../../lib/docs";
import { resolveImage } from "../../lib/images";
import Button from "../ui/Button.astro";

// Hero usa foto de acción 2024 (LIEBHERR LTM 1100-5.3 en operación)
const heroImage = resolveImage("/assets/images/hero-grua-accion-2024-01.avif");
---

<section
  id="hero"
  class="relative flex min-h-svh flex-col justify-end overflow-hidden bg-ink pt-16"
>
  <!-- Background image -->
  <div class="absolute inset-0">
    <img
      src={heroImage}
      alt="Grúa Liebherr LTM 1100 de Grúas del Vallès en operación"
      class="h-full w-full object-cover object-center opacity-40 sm:opacity-60"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Gradient overlay -->
    <div
      class="absolute inset-0 bg-linear-to-t from-ink via-ink/85 to-ink/30 sm:via-ink/60 sm:to-transparent"
    >
    </div>
    <!-- Vignette to anchor the composition and add depth -->
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(125% 110% at 30% 10%, transparent 50%, rgb(10 10 10 / 0.6) 100%);"
    >
    </div>
    <!-- Red accent line top -->
    <div class="absolute top-16 left-0 h-1 w-24 bg-accent"></div>
  </div>

  <!-- Content -->
  <div class="container-wide relative z-10 section-padding pb-10 sm:pb-14">
    <div class="max-w-3xl">
      <!-- Headline -->
      <h1
        class="mb-5 text-[clamp(2.6rem,10vw,4.5rem)] font-black leading-[0.9] tracking-tight text-white sm:mb-6 sm:text-6xl lg:text-7xl"
        data-reveal
        data-reveal-delay="1"
      >
        Alquiler de<br />
        <span class="text-accent">grúas industriales</span><br />
        hasta 700&nbsp;Tn
      </h1>

      <!-- Subheadline -->
      <p
        class="mb-8 max-w-md text-base leading-relaxed text-white/60 sm:mb-10 sm:max-w-xl sm:text-lg sm:text-muted"
        data-reveal
        data-reveal-delay="2"
      >
        Más de 30 unidades propias en Cataluña<br /> Servicio de emergencia <strong
          class="text-white/90 sm:text-white">24 h · 365 días</strong
        >
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-4"
        data-reveal
        data-reveal-delay="3"
      >
        <Button
          href="#contacto"
          icon="lucide:arrow-right"
          class="w-full sm:w-auto"
        >
          Solicitar presupuesto
        </Button>
        <Button
          href="tel:+34938497022"
          variant="outline"
          icon="lucide:phone"
          iconPosition="start"
          class="hidden border-white text-white hover:bg-white hover:text-ink! sm:inline-flex sm:w-auto"
        >
          93 849 70 22
        </Button>
        <Button
          href={catalogo.url}
          download={catalogo.filename}
          variant="ghost"
          icon="lucide:download"
          iconPosition="start"
          class="hidden text-white hover:text-accent sm:inline-flex sm:w-auto"
        >
          {catalogo.label}
        </Button>
      </div>
    </div>
  </div>

  <!-- Stats band — full width, anchored to bottom of hero -->
  <dl class="relative z-10 grid grid-cols-3 gap-px bg-white/10" data-reveal>
    {
      [
        { value: "+55", label: "Años de experiencia" },
        { value: "30+", label: "Unidades propias" },
        { value: "700 Tn", label: "Capacidad máx." },
      ].map(({ value, label }) => (
        <div class="border-t-2 border-accent bg-black/50 px-4 py-5 backdrop-blur-sm sm:px-8 sm:py-6">
          <dt class="sr-only">{label}</dt>
          <dd>
            <span class="block text-2xl font-black leading-none tracking-tight text-white sm:text-3xl">
              {value}
            </span>
            <span class="mt-1.5 block text-[11px] uppercase tracking-wider text-white/50 sm:text-xs">
              {label}
            </span>
          </dd>
        </div>
      ))
    }
  </dl>

  <!-- Scroll cue -->
  <a
    href="#flota"
    class="absolute bottom-7 right-7 z-10 hidden items-center gap-3 text-xs font-semibold uppercase tracking-widest text-muted transition-colors hover:text-white lg:inline-flex"
    aria-label="Desplazarse a la flota"
  >
    Scroll
    <span
      class="relative block h-9 w-px overflow-hidden bg-white/20"
      aria-hidden="true"
    >
      <span class="animate-scroll-cue absolute inset-x-0 top-0 h-1/2 bg-accent"
      ></span>
    </span>
  </a>
</section>
