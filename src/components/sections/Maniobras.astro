---
import { getCollection } from "astro:content";
import Section from "../ui/Section.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";
import ManiobraCard from "../maniobras/ManiobraCard.astro";

// Fuente única: colección «maniobras» (ver src/content.config.ts)
const entries = await getCollection("maniobras");
const maniobras = entries
  .map((e) => ({ slug: e.id, ...e.data }))
  .sort((a, b) => a.orden - b.orden);

// Las que tienen imagen primero, luego el resto
const conFoto = maniobras.filter((m) => m.imagenes.length > 0);
const sinFoto = maniobras.filter((m) => m.imagenes.length === 0);
const ordenadas = [...conFoto, ...sinFoto];
const destacada = conFoto[0];
---

<Section id="maniobras" bg="alt" title="Casos reales. Resultados reales.">
  <p slot="intro">
    Cada maniobra es un reto técnico. Aquí mostramos algunos de los trabajos que
    mejor definen nuestra capacidad.
  </p>

  <!-- Featured: primera con foto en grande -->
  {
    destacada && (
      <a
        href={`/maniobras/${destacada.slug}`}
        class="group mb-px grid gap-px bg-muted lg:grid-cols-2"
      >
        <div class="relative aspect-4/3 overflow-hidden bg-ink">
          <img
            src={destacada.imagenes[0]}
            alt={destacada.titulo}
            class="h-full w-full object-cover opacity-80 transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-linear-to-t from-ink/80 to-transparent" />
        </div>
        <div class="flex flex-col justify-end bg-ink p-6 text-white sm:p-8">
          <div class="mb-4 flex flex-wrap gap-2">
            {destacada.contrapesos_t && (
              <Badge variant="solid">
                {destacada.contrapesos_t} Tn contrapesos
              </Badge>
            )}
            {destacada.radio_m && (
              <span class="border border-white/20 px-2 py-0.5 text-xs text-muted">
                Radio {destacada.radio_m} m
              </span>
            )}
          </div>
          <h3 class="mb-3 text-2xl font-bold group-hover:text-accent transition-colors">
            {destacada.titulo}
          </h3>
          <p class="text-sm text-muted leading-relaxed line-clamp-4">
            {destacada.descripcion}
          </p>
        </div>
      </a>
    )
  }

  <!-- Grid resto -->
  <div class="grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3">
    {ordenadas.slice(1, 4).map((m) => <ManiobraCard maniobra={m} />)}
  </div>

  <div class="mt-12 text-center">
    <Button href="/maniobras" variant="outline" icon="lucide:arrow-right">
      Ver todas las maniobras
    </Button>
  </div>
</Section>
