---
const testimonios = [
  {
    nombre: "Jordi Puigdomènech",
    empresa: "Construmat Girona, S.L.",
    rol: "Jefe de obra",
    texto:
      "Llevamos 8 años contratando a Grúas del Vallès para nuestras obras de estructura. Puntualidad total, operadores certificados y grúas impecables. No hemos necesitado buscar alternativas.",
    estrellas: 5,
  },
  {
    nombre: "Marta Solà",
    empresa: "Solà Instal·lacions Industrials",
    rol: "Directora de operaciones",
    texto:
      "Nos ayudaron a instalar maquinaria de 85 Tn en un espacio con acceso muy restringido. El estudio de maniobra previo fue clave; llegaron con todo planificado al milímetro.",
    estrellas: 5,
  },
  {
    nombre: "Ferran Comas",
    empresa: "Promotora Residencial BCN",
    rol: "Project Manager",
    texto:
      "Llamé a las 11 de la noche por una emergencia en obra. En menos de dos horas tenían una grúa en el lugar. Ese nivel de servicio no lo encuentras en cualquier sitio.",
    estrellas: 5,
  },
  {
    nombre: "Ana Torres",
    empresa: "Enel Green Power España",
    rol: "Responsable de mantenimiento",
    texto:
      "Trabajamos con ellos en el mantenimiento de aerogeneradores en la zona del Penedès. Profesionalidad y seguridad ante todo. ISO 9001 no es solo un papel en su caso.",
    estrellas: 5,
  },
  {
    nombre: "Pere Vilaró",
    empresa: "Grups Escènics Fura",
    rol: "Director técnico",
    texto:
      "Colaboramos en montajes para festivales y espectáculos en altura. Siempre se adaptan a horarios imposibles y el equipo humano es excelente. Los recomendamos sin reservas.",
    estrellas: 5,
  },
  {
    nombre: "Cristina Mas",
    empresa: "Hospital de Granollers",
    rol: "Responsable de infraestructuras",
    texto:
      "Gestionaron el izado de equipamiento médico de gran peso sin interrumpir la actividad del centro. Coordinación perfecta y tolerancia cero para imprevistos.",
    estrellas: 5,
  },
];

const totalReviews = testimonios.length;
const avgRating = 5;

// En móvil mostramos solo las principales; el resto se despliega con el botón.
const VISIBLE_ON_MOBILE = 3;
---

<!-- AggregateRating JSON-LD -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "Grúas del Vallès, S.A.",
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: avgRating,
      bestRating: 5,
      reviewCount: totalReviews,
    },
    review: testimonios.map((t) => ({
      "@type": "Review",
      author: { "@type": "Person", name: t.nombre },
      reviewBody: t.texto,
      reviewRating: {
        "@type": "Rating",
        ratingValue: t.estrellas,
        bestRating: 5,
      },
    })),
  })}
/>

<section class="section-padding bg-surface-alt" aria-labelledby="testimonios-title">
  <div class="container-wide">
    <div class="mb-12 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow">Clientes satisfechos</p>
        <h2 id="testimonios-title" class="text-3xl font-black sm:text-4xl">
          Lo que dicen de nosotros
        </h2>
      </div>
      <!-- Aggregate badge -->
      <div class="flex items-center gap-2">
        <span class="flex">
          {Array.from({ length: 5 }).map(() => (
            <svg aria-hidden="true" class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </span>
        <p class="text-sm font-semibold text-ink">{avgRating}/5 · {totalReviews} valoraciones</p>
      </div>
    </div>

    <div id="testimonios-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        testimonios.map((t, i) => (
          <article
            class:list={[
              "flex flex-col gap-4 border-t-2 border-muted bg-surface p-6 shadow-card transition-colors duration-200 hover:border-accent",
              { "testimonio-extra": i >= VISIBLE_ON_MOBILE },
            ]}
            data-reveal
            data-reveal-delay={String((i % 3) + 1)}
          >
            <!-- Stars -->
            <span class="flex gap-0.5" aria-label={`${t.estrellas} de 5 estrellas`}>
              {Array.from({ length: t.estrellas }).map(() => (
                <svg aria-hidden="true" class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </span>

            <!-- Quote -->
            <blockquote class="flex-1 text-sm leading-relaxed text-ink-secondary">
              "{t.texto}"
            </blockquote>

            <!-- Author -->
            <footer class="border-t border-muted/60 pt-4">
              <p class="text-sm font-bold text-ink">{t.nombre}</p>
              <p class="text-xs text-ink-secondary">{t.rol} · {t.empresa}</p>
            </footer>
          </article>
        ))
      }
    </div>

    <!-- Toggle solo en móvil: el resto de valoraciones está oculto por defecto -->
    <div class="mt-8 flex justify-center lg:hidden">
      <button
        id="testimonios-more"
        type="button"
        aria-expanded="false"
        aria-controls="testimonios-grid"
        class="btn btn-sm border-2 border-muted text-ink transition-colors hover:border-accent hover:text-accent"
      >
        <span data-more-label>Ver más valoraciones</span>
      </button>
    </div>
  </div>
</section>

<style>
  /* Las valoraciones extra solo se ocultan en móvil; en desktop siempre visibles. */
  @media (max-width: 1023px) {
    .testimonio-extra {
      display: none;
    }
    #testimonios-grid.is-expanded .testimonio-extra {
      display: flex;
    }
  }
</style>

<script>
  const grid = document.getElementById("testimonios-grid");
  const btn = document.getElementById("testimonios-more");
  const label = btn?.querySelector<HTMLElement>("[data-more-label]");

  btn?.addEventListener("click", () => {
    const expanded = grid?.classList.toggle("is-expanded") ?? false;
    btn.setAttribute("aria-expanded", String(expanded));
    if (label) {
      label.textContent = expanded
        ? "Ver menos valoraciones"
        : "Ver más valoraciones";
    }
    // Revela las tarjetas recién mostradas (scroll-reveal one-shot).
    if (expanded) {
      grid
        ?.querySelectorAll<HTMLElement>(".testimonio-extra[data-reveal]")
        .forEach((el) => el.classList.add("is-visible"));
    }
  });
</script>
