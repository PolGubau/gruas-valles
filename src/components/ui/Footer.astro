---
import { Icon } from "astro-icon/components";
import localidades from "../../data/localidades.json";

const year = new Date().getFullYear();

const serviciosLinks = [
  { href: "/flota", label: "Flota" },
  { href: "/servicios", label: "Servicios" },
  { href: "/maniobras", label: "Maniobras" },
  { href: "/galeria", label: "Galería" },
];

const empresaLinks = [
  { href: "/nosotros", label: "Nosotros" },
  { href: "/seguridad", label: "Seguridad" },
  { href: "/organismos", label: "Organismos" },
  { href: "/blog", label: "Noticias" },
  { href: "/contacto", label: "Contacto" },
];

const zonas = localidades.slice(0, 6);

const legalLinks = [
  { href: "/legal/aviso-legal", label: "Aviso legal" },
  { href: "/legal/privacidad", label: "Política de privacidad" },
  { href: "/legal/politica-cookies", label: "Política de cookies" },
];
---

<footer class="bg-ink text-muted">
  <div class="container-wide py-12">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-6">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a
          href="/"
          class="mb-4 inline-block"
          aria-label="Grúas del Vallès - inicio"
        >
          <img
            src="/logo.png"
            alt="Grúas del Vallès"
            class="h-12 w-auto brightness-0 invert"
            loading="lazy"
          />
        </a>
        <p class="text-sm leading-relaxed">
          Empresa líder en alquiler de grúas industriales en Cataluña desde
          1968. Certificados ISO 9001. Cobertura 24h/365 días.
        </p>
        <div class="mt-4 flex items-center gap-3">
          <a
            href="https://www.youtube.com/channel/UCGAXK9VBR-OSxCsV3k2Ntkg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Canal de YouTube de Grúas del Vallès"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-muted transition-colors hover:bg-[#FF0000] hover:text-white"
          >
            <Icon name="lucide:youtube" class="h-4 w-4" aria-hidden="true" />
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
        >
          Navegación
        </p>
        <ul class="space-y-2 text-sm">
          {
            navLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="hover:text-accent transition-colors">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Institucional -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
        >
          Empresa
        </p>
        <ul class="space-y-2 text-sm">
          {
            institutionalLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="hover:text-accent transition-colors">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Zonas -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
        >
          Zonas
        </p>
        <ul class="space-y-2 text-sm">
          {
            zonas.map((z) => (
              <li>
                <a
                  href={`/alquiler-gruas/${z.slug}`}
                  class="hover:text-accent transition-colors"
                >
                  Grúas en {z.nombre}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contacto rápido -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
        >
          Contacto rápido
        </p>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="tel:+34938497022"
              class="flex items-center gap-2 hover:text-accent transition-colors"
            >
              <Icon
                name="lucide:phone"
                class="h-4 w-4 flex-shrink-0 text-accent"
                aria-hidden="true"
              />
              93 849 70 22
            </a>
          </li>
          <li class="text-xs text-muted-dark">Emergencias 24/365:</li>
          <li>
            <a
              href="tel:+34669296954"
              class="flex items-center gap-2 text-accent hover:underline"
            >
              669 29 69 54
            </a>
          </li>
          <li>
            <a
              href="tel:+34669296949"
              class="flex items-center gap-2 text-accent hover:underline"
            >
              669 29 69 49
            </a>
          </li>
          <li class="pt-2">
            <a
              href="mailto:gruasdelvalles@gruasdelvalles.com"
              class="flex items-center gap-2 text-xs hover:text-accent transition-colors break-all"
            >
              <Icon
                name="lucide:mail"
                class="h-4 w-4 flex-shrink-0 text-accent"
                aria-hidden="true"
              />
              gruasdelvalles@gruasdelvalles.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p
          class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
        >
          Legal
        </p>
        <ul class="space-y-2 text-sm">
          {
            legalLinks.map(({ href, label }) => (
              <li>
                <a href={href} class="hover:text-accent transition-colors">
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-xs sm:flex-row"
    >
      <div class="flex flex-col gap-2 sm:flex-row sm:gap-6">
        <p>© {year} Grúas del Vallès, S.A. · CIF A08603888</p>
        <p>Avda. San Julián 64-66 · Polígono Congost · 08403 Granollers</p>
      </div>
      <p class="text-[10px] opacity-40 transition-opacity hover:opacity-100">
        Programado por <a
          href="https://doscientos.es"
          target="_blank"
          rel="noopener"
          class="hover:text-white">Doscientos</a
        > · <a
          href="https://polgubau.com"
          target="_blank"
          rel="noopener"
          class="hover:text-white">Pol Gubau</a
        >
      </p>
    </div>
  </div>
</footer>
