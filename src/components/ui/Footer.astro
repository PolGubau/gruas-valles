---
import { Icon } from "astro-icon/components";
import localidades from "../../data/localidades.json";
import { catalogo } from "../../lib/docs";

const year = new Date().getFullYear();

const serviciosLinks = [
  { href: "/flota", label: "Flota" },
  { href: "/servicios", label: "Servicios" },
];

const empresaLinks = [
  { href: "/nosotros", label: "Nosotros" },
  { href: "/seguridad", label: "Seguridad" },
  { href: "/organismos", label: "Organismos" },
  { href: "/blog", label: "Noticias" },
  { href: "/trabaja-con-nosotros", label: "Trabaja con nosotros" },
  { href: "/contacto", label: "Contacto" },
];

const zonas = localidades.slice(0, 6);

const waPhone = "34669296954";
const waMessage =
  "Hola, me gustaría solicitar información / presupuesto sobre el alquiler de grúas.";
const waHref = `https://wa.me/${waPhone}?text=${encodeURIComponent(waMessage)}`;

const legalLinks = [
  { href: "/legal/aviso-legal", label: "Aviso legal" },
  { href: "/legal/privacidad", label: "Política de privacidad" },
  { href: "/legal/politica-cookies", label: "Política de cookies" },
];
---

<footer class="bg-ink text-muted">
  <div class="container-wide py-14">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-8">
      <!-- Brand + contacto -->
      <div class="lg:col-span-5">
        <a
          href="/"
          class="mb-5 inline-block"
          aria-label="Grúas del Vallès - inicio"
        >
          <img
            src="/logo.png"
            alt="Grúas del Vallès"
            class="h-12 w-auto brightness-0 invert"
            loading="lazy"
          />
        </a>
        <p class="max-w-sm text-sm leading-relaxed">
          Empresa líder en alquiler de grúas industriales en Cataluña desde
          1968. Cobertura 24h/365 días.
        </p>

        <div class="mt-8 space-y-4">
          <a
            href="tel:+34938497022"
            class="inline-flex items-center gap-2.5 text-lg font-bold text-white transition-colors hover:text-accent"
          >
            <Icon
              name="lucide:phone"
              class="h-5 w-5 shrink-0 text-accent"
              aria-hidden="true"
            />
            93 849 70 22
          </a>

          <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm">
            <span
              class="text-xs font-semibold uppercase tracking-wider text-muted-dark"
            >
              Emergencias 24/365
            </span>
            <a href="tel:+34669296954" class="text-accent hover:underline">
              669 29 69 54
            </a>
            <a href="tel:+34669296949" class="text-accent hover:underline">
              669 29 69 49
            </a>
          </div>

          <a
            href="mailto:gruasdelvalles@gruasdelvalles.com"
            class="inline-flex items-center gap-2.5 text-sm transition-colors hover:text-accent"
          >
            <Icon
              name="lucide:mail"
              class="h-4 w-4 shrink-0 text-accent"
              aria-hidden="true"
            />
            gruasdelvalles@gruasdelvalles.com
          </a>

          <a
            href={catalogo.url}
            download={catalogo.filename}
            class="inline-flex items-center gap-2.5 border-2 border-white/20 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:border-accent hover:text-accent"
          >
            <Icon
              name="lucide:download"
              class="h-4 w-4 shrink-0 text-accent"
              aria-hidden="true"
            />
            {catalogo.label}
          </a>
        </div>

        <div class="mt-8 flex items-center gap-3">
          <a
            href="https://www.youtube.com/channel/UCGAXK9VBR-OSxCsV3k2Ntkg"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Canal de YouTube de Grúas del Vallès"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-muted transition-colors hover:bg-[#FF0000] hover:text-white"
          >
            <Icon name="lucide:youtube" class="h-4 w-4" aria-hidden="true" />
          </a>
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Escríbenos por WhatsApp"
            class="flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-muted transition-colors hover:bg-[#25D366] hover:text-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.728-.985zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
              ></path>
            </svg>
          </a>
        </div>
      </div>

      <!-- Columnas de enlaces -->
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:col-span-7">
        <!-- Servicios -->
        <div>
          <p
            class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
          >
            Servicios
          </p>
          <ul class="space-y-2.5 text-sm">
            {
              serviciosLinks.map(({ href, label }) => (
                <li>
                  <a href={href} class="transition-colors hover:text-accent">
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Empresa -->
        <div>
          <p
            class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
          >
            Empresa
          </p>
          <ul class="space-y-2.5 text-sm">
            {
              empresaLinks.map(({ href, label }) => (
                <li>
                  <a href={href} class="transition-colors hover:text-accent">
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Cobertura -->
        <div class="col-span-2 sm:col-span-1">
          <p
            class="mb-4 text-xs font-semibold uppercase tracking-wider text-white"
          >
            Cobertura
          </p>
          <ul class="space-y-2.5 text-sm">
            {
              zonas.map((z) => (
                <li>
                  <a
                    href={`/alquiler-gruas/${z.slug}`}
                    class="transition-colors hover:text-accent"
                  >
                    Grúas en {z.nombre}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href="/alquiler-gruas"
                class="font-semibold text-accent hover:underline"
              >
                Ver toda la cobertura →
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Barra inferior -->
    <div
      class="mt-14 flex flex-col gap-6 border-t border-white/10 pt-8 text-xs lg:flex-row lg:items-center lg:justify-between"
    >
      <div class="space-y-1.5">
        <p>© {year} Grúas del Vallès, S.A. · CIF A08603888</p>
        <p class="text-muted-dark">
          Avda. San Julián 64-66 · Polígono Congost · 08403 Granollers
        </p>
      </div>

      <nav
        class="flex flex-wrap items-center gap-x-5 gap-y-2"
        aria-label="Enlaces legales"
      >
        {
          legalLinks.map(({ href, label }) => (
            <a href={href} class="transition-colors hover:text-white">
              {label}
            </a>
          ))
        }
      </nav>
    </div>

    <p class="mt-6 text-[10px] opacity-40 transition-opacity hover:opacity-100">
      Programado por <a
        href="https://doscientos.es"
        target="_blank"
        rel="noopener"
        class="hover:text-white">Doscientos</a
      ><a
        href="https://polgubau.com"
        target="_blank"
        rel="noopener"
        class="opacity-0 hover:text-white">Pol Gubau</a
      >
    </p>
  </div>
</footer>
