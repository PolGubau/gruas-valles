---
/**
 * MobileBar — barra sticky de conversión, solo móvil (sm:hidden).
 * Dos acciones directas: llamada + WhatsApp. Sin FAB redundante.
 */
const phone = "tel:+34938497022";
const phoneDisplay = "93 849 70 22";
const waPhone = "34938497022";
const waMessage =
  "Hola, me gustaría solicitar información o presupuesto para el alquiler de una grúa.";
const waHref = `https://wa.me/${waPhone}?text=${encodeURIComponent(waMessage)}`;
---

<div
  class="fixed bottom-0 left-0 right-0 z-50 flex h-16 sm:hidden"
  style="padding-bottom: env(safe-area-inset-bottom);"
  aria-label="Contacto rápido"
  role="navigation"
>
  <!-- Llamar -->
  <a
    href={phone}
    class="flex flex-1 items-center justify-center gap-2.5 bg-ink text-white transition-colors active:bg-zinc-800"
    aria-label={`Llamar al ${phoneDisplay}`}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 text-white/60"
    >
      <path
        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.68 13.5 19.79 19.79 0 0 1 1.57 4.9 2 2 0 0 1 3.51 2.72h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10a16 16 0 0 0 6.06 6.06l.83-.83a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 17.5z"
      ></path>
    </svg>
    <span class="text-sm font-semibold tracking-tight">{phoneDisplay}</span>
  </a>

  <!-- Divisor -->
  <div class="w-px shrink-0 bg-white/10" aria-hidden="true"></div>

  <!-- WhatsApp -->
  <a
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    class="flex flex-1 items-center justify-center gap-2.5 bg-[#25D366] text-white transition-colors active:bg-[#1ebe5d]"
    aria-label="Escríbenos por WhatsApp"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
      class="shrink-0 text-white/80"
    >
      <path
        d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.728-.985zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
      ></path>
    </svg>
    <span class="text-sm font-bold tracking-tight">WhatsApp</span>
  </a>
</div>
