---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/flota", label: "Flota" },
  { href: "/servicios", label: "Servicios" },
  { href: "/maniobras", label: "Maniobras" },
  { href: "/galeria", label: "Galería" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/blog", label: "Noticias" },
];

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  id="navbar"
  class="fixed top-0 z-50 w-full border-b border-transparent bg-white/90 backdrop-blur-md transition-[box-shadow,border-color] duration-300"
>
  <div class="container-wide flex h-16 items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center"
      aria-label="Grúas del Vallès - inicio"
    >
      <img
        src="/logo.png"
        alt="Grúas del Vallès"
        class="h-10 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-7 lg:flex" aria-label="Principal">
      {
        links.map(({ href, label }) => (
          <a
            href={href}
            aria-current={isActive(href) ? "page" : undefined}
            class="nav-link relative text-sm font-medium text-ink-secondary transition-colors hover:text-accent aria-[current=page]:text-accent"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- CTA -->
    <div class="hidden items-center gap-5 lg:flex">
      <a
        href="tel:+34938497022"
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-ink transition-colors hover:text-accent"
      >
        <Icon name="lucide:phone" width={16} height={16} aria-hidden="true" />
        93 849 70 22
      </a>
      <a
        href="/contacto"
        class="btn btn-sm bg-accent text-white hover:bg-accent-dark"
      >
        Presupuesto
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="hamburger p-2 text-ink lg:hidden"
    >
      <span class="hamburger-box" aria-hidden="true">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu bg-white lg:hidden">
    <div class="min-h-0 overflow-hidden">
      <nav
        class="container-wide flex flex-col border-t border-muted/60 py-4"
        aria-label="Móvil"
      >
        {
          links.map(({ href, label }) => (
            <a
              href={href}
              aria-current={isActive(href) ? "page" : undefined}
              class="mobile-link border-b border-muted/40 py-3 text-sm font-medium text-ink transition-colors last:border-0 hover:text-accent aria-[current=page]:text-accent"
            >
              {label}
            </a>
          ))
        }
        <a
          href="/contacto"
          class="btn btn-sm mt-4 justify-center bg-accent text-white hover:bg-accent-dark"
        >
          Solicitar presupuesto
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 0;
    background: var(--color-accent);
    transition: width 0.25s var(--ease-out-quart);
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 100%;
  }

  /* Hamburguesa animada: tres barras que se transforman en una X. */
  .hamburger-box {
    position: relative;
    display: block;
    width: 24px;
    height: 24px;
  }
  .hamburger-bar {
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s linear;
  }
  .hamburger-bar:nth-child(1) {
    top: 5px;
  }
  .hamburger-bar:nth-child(2) {
    top: 11px;
  }
  .hamburger-bar:nth-child(3) {
    top: 17px;
  }
  .hamburger.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Despliegue suave del panel móvil (sin medir la altura). */
  @media (max-width: 1023px) {
    .mobile-menu {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.3s var(--ease-out-quart);
    }
    .mobile-menu.is-open {
      grid-template-rows: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-bar,
    .mobile-menu {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const navbar = document.getElementById("navbar")!;

  const setOpen = (open: boolean) => {
    menu.classList.toggle("is-open", open);
    toggle.classList.toggle("is-open", open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
  };

  toggle.addEventListener("click", () =>
    setOpen(!menu.classList.contains("is-open")),
  );
  menu
    .querySelectorAll(".mobile-link")
    .forEach((link) => link.addEventListener("click", () => setOpen(false)));

  // Scroll shadow
  window.addEventListener("scroll", () => {
    const scrolled = window.scrollY > 10;
    navbar.classList.toggle("shadow-sm", scrolled);
    navbar.classList.toggle("border-muted/40", scrolled);
  });
</script>
