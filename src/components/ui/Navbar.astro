---
import { languages } from "@i18n/ui";
import {
  type UiKey,
  getLangFromUrl,
  getRouteFromUrl,
  useTranslatedPath,
  useTranslations,
} from "@i18n/utils";
import { Icon } from "astro-icon/components";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const localizePath = useTranslatedPath(lang);
// Ruta actual sin prefijo de idioma, para construir el cambio de idioma.
const route = getRouteFromUrl(Astro.url);

const links: { href: string; key: UiKey }[] = [
  { href: "/flota", key: "nav.flota" },
  { href: "/servicios", key: "nav.servicios" },
  { href: "/nosotros", key: "nav.nosotros" },
  { href: "/blog", key: "nav.blog" },
];

const isActive = (href: string) =>
  href === "/" ? route === "/" : route.startsWith(href);
---

<header
  id="navbar"
  class="fixed top-0 z-50 w-full border-b border-transparent bg-white/90 backdrop-blur-md transition-[box-shadow,border-color] duration-300"
>
  <div class="container-wide flex h-24 items-center justify-between">
    <!-- Logo -->
    <a
      href={localizePath("/")}
      class="flex items-center"
      aria-label={t("a11y.home")}
    >
      <img
        src="/logo.png"
        alt="Grúas del Vallès"
        class="h-16 w-auto"
        loading="eager"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Principal">
      {
        links.map(({ href, key }) => (
          <a
            href={localizePath(href)}
            aria-current={isActive(href) ? "page" : undefined}
            class="nav-link relative text-base font-semibold text-ink-secondary transition-colors hover:text-accent aria-[current=page]:text-accent"
          >
            {t(key)}
          </a>
        ))
      }
    </nav>

    <!-- CTA -->
    <div class="hidden items-center gap-6 lg:flex">
      <a
        href="tel:+34938497022"
        class="inline-flex items-center gap-2 text-lg font-bold text-ink transition-colors hover:text-accent"
      >
        <Icon name="lucide:phone" width={22} height={22} aria-hidden="true" />
        93 849 70 22
      </a>
      <!-- Language selector -->
      <div class="lang-selector relative">
        <button
          type="button"
          id="lang-toggle"
          aria-haspopup="menu"
          aria-expanded="false"
          aria-label={t("nav.langLabel")}
          class="inline-flex items-center gap-1.5 rounded border border-muted/60 px-3 py-2 text-sm font-bold uppercase tracking-wider text-ink-secondary transition-colors hover:border-accent hover:text-accent"
        >
          <Icon name="lucide:globe" width={16} height={16} aria-hidden="true" />
          <span>{lang}</span>
          <Icon
            name="lucide:chevron-down"
            width={14}
            height={14}
            class="lang-chevron transition-transform duration-200"
            aria-hidden="true"
          />
        </button>
        <ul
          id="lang-menu"
          role="menu"
          aria-label={t("nav.langLabel")}
          class="lang-menu absolute right-0 top-full mt-1 hidden min-w-full overflow-hidden rounded border border-muted/40 bg-white shadow-pop"
        >
          {
            Object.entries(languages).map(([code, label]) => (
              <li role="none">
                <a
                  role="menuitem"
                  href={localizePath(route, code as keyof typeof languages)}
                  hreflang={code}
                  aria-current={code === lang ? "true" : undefined}
                  class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold hover:bg-accent-soft hover:text-accent aria-current:text-accent"
                >
                  <span class="w-5 text-center text-xs font-bold uppercase">
                    {code}
                  </span>
                  {label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="hamburger p-2 text-ink lg:hidden"
    >
      <span class="hamburger-box" aria-hidden="true">
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu bg-white lg:hidden">
    <div class="min-h-0 overflow-hidden">
      <nav
        class="container-wide flex flex-col border-t border-muted/60 py-4"
        aria-label="Móvil"
      >
        {
          links.map(({ href, key }) => (
            <a
              href={localizePath(href)}
              aria-current={isActive(href) ? "page" : undefined}
              class="mobile-link border-b border-muted/40 py-3 text-sm font-medium text-ink transition-colors last:border-0 hover:text-accent aria-[current=page]:text-accent"
            >
              {t(key)}
            </a>
          ))
        }
        <a
          href={localizePath("/contacto")}
          class="btn btn-sm mt-4 justify-center bg-accent text-white hover:bg-accent-dark"
        >
          {t("cta.presupuesto")}
        </a>
      </nav>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    height: 2px;
    width: 0;
    background: var(--color-accent);
    transition: width 0.25s var(--ease-out-quart);
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 100%;
  }

  /* Hamburguesa animada: tres barras que se transforman en una X. */
  .hamburger-box {
    position: relative;
    display: block;
    width: 24px;
    height: 24px;
  }
  .hamburger-bar {
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
    transition:
      transform 0.3s var(--ease-out-quart),
      opacity 0.2s linear;
  }
  .hamburger-bar:nth-child(1) {
    top: 5px;
  }
  .hamburger-bar:nth-child(2) {
    top: 11px;
  }
  .hamburger-bar:nth-child(3) {
    top: 17px;
  }
  .hamburger.is-open .hamburger-bar:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .hamburger.is-open .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger.is-open .hamburger-bar:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* Despliegue suave del panel móvil (sin medir la altura). */
  @media (max-width: 1023px) {
    .mobile-menu {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.3s var(--ease-out-quart);
    }
    .mobile-menu.is-open {
      grid-template-rows: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hamburger-bar,
    .mobile-menu {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const navbar = document.getElementById("navbar")!;

  const setOpen = (open: boolean) => {
    menu.classList.toggle("is-open", open);
    toggle.classList.toggle("is-open", open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Cerrar menú" : "Abrir menú");
  };

  toggle.addEventListener("click", () =>
    setOpen(!menu.classList.contains("is-open")),
  );
  menu
    .querySelectorAll(".mobile-link")
    .forEach((link) => link.addEventListener("click", () => setOpen(false)));

  // Scroll shadow
  window.addEventListener("scroll", () => {
    const scrolled = window.scrollY > 10;
    navbar.classList.toggle("shadow-sm", scrolled);
    navbar.classList.toggle("border-muted/40", scrolled);
  });

  // Language selector: solo abre/cierra el menú. Cada opción es un enlace real
  // que navega a la misma ruta en el locale destino (localizePath).
  const langToggle = document.getElementById("lang-toggle")!;
  const langMenu = document.getElementById("lang-menu")!;
  const langChevron = langToggle.querySelector(".lang-chevron") as HTMLElement;

  const setLangOpen = (open: boolean) => {
    langMenu.classList.toggle("hidden", !open);
    langToggle.setAttribute("aria-expanded", String(open));
    langChevron.style.transform = open ? "rotate(180deg)" : "";
  };

  langToggle.addEventListener("click", (e) => {
    e.stopPropagation();
    setLangOpen(langMenu.classList.contains("hidden"));
  });

  document.addEventListener("click", () => setLangOpen(false));
</script>
