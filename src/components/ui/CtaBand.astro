---
import { Icon } from "astro-icon/components";
import { catalogo } from "../../lib/docs";

interface Props {
  eyebrow?: string;
  title?: string;
  text?: string;
  class?: string;
}

const {
  eyebrow = "Presupuesto sin compromiso",
  title = "¿Tiene una maniobra entre manos?",
  text = "Nuestro equipo técnico estudia su proyecto y le responde en menos de 24 horas con una propuesta detallada.",
  class: extra = "",
} = Astro.props;
---

<section class={`bg-accent text-white ${extra}`}>
  <div
    class="container-wide flex flex-col gap-8 py-16 lg:flex-row lg:items-center lg:justify-between lg:py-20"
  >
    <div class="max-w-2xl">
      <p
        class="mb-2 text-xs font-semibold uppercase tracking-wider text-white/70"
      >
        {eyebrow}
      </p>
      <h2 class="text-3xl font-black leading-tight sm:text-4xl">{title}</h2>
      <p class="mt-4 text-sm leading-relaxed text-white/85">{text}</p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row">
      <a
        href="/contacto"
        class="btn btn-md justify-center bg-white text-accent hover:bg-ink hover:text-white"
      >
        <Icon
          name="lucide:file-text"
          width={18}
          height={18}
          aria-hidden="true"
        />
        Solicitar presupuesto
      </a>
      <a
        href="tel:+34938497022"
        class="btn btn-md justify-center border-2 border-white/40 text-white hover:bg-white/10"
      >
        <Icon name="lucide:phone" width={18} height={18} aria-hidden="true" />
        93 849 70 22
      </a>
      <a
        href={catalogo.url}
        download={catalogo.filename}
        class="btn btn-md justify-center border-2 border-white/40 text-white hover:bg-white/10"
      >
        <Icon
          name="lucide:download"
          width={18}
          height={18}
          aria-hidden="true"
        />
        {catalogo.label}
      </a>
    </div>
  </div>
</section>
