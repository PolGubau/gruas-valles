---
const email = "gruasdelvalles@gruasdelvalles.com";
const subject = "Solicitud de presupuesto";
const body =
  "Hola,\n\nMe gustaría solicitar un presupuesto para:\n\n- Tipo de trabajo:\n- Tonelaje aproximado:\n- Fecha prevista:\n- Ubicación:\n\nGracias.";
const href = `mailto:${email}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

// WhatsApp: en móvil sustituye al FAB flotante (oculto en <sm) y se muestra
// junto al botón de presupuesto. En desktop sigue el FAB en WhatsAppFAB.astro.
const waPhone = "34669296954";
const waMessage =
  "Hola, me gustaría solicitar información / presupuesto sobre el alquiler de grúas.";
const waHref = `https://wa.me/${waPhone}?text=${encodeURIComponent(waMessage)}`;
---

<div
  id="float-cta"
  data-hidden
  class="fixed bottom-6 right-4 z-50 flex translate-y-24 items-center gap-3 opacity-0 transition-all duration-300 ease-[var(--ease-out-quart)] data-[hidden]:pointer-events-none sm:right-6"
>
  <!-- WhatsApp (solo móvil, reemplaza al FAB flotante) -->
  <a
    href={waHref}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Escríbenos por WhatsApp"
    class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[#25D366] text-white shadow-pop transition-transform duration-200 hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#25D366] focus-visible:ring-offset-2 sm:hidden"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 0 1 8.413 3.488 11.824 11.824 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.728-.985zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"
      ></path>
    </svg>
  </a>

  <!-- Pedir presupuesto -->
  <a
    href={href}
    aria-label="Pedir presupuesto por email"
    class="group flex items-center gap-3 bg-accent px-4 py-3 text-white shadow-pop transition-all duration-300 ease-[var(--ease-out-quart)] hover:bg-accent-dark hover:shadow-[0_16px_48px_-12px_rgba(214,11,12,0.55)] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-accent sm:px-5 sm:py-3.5"
  >
    <!-- Mail icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0"
    >
      <rect width="20" height="16" x="2" y="4" rx="2"></rect>
      <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
    </svg>

    <span class="text-sm font-semibold uppercase tracking-wider leading-none">
      Pedir presupuesto
    </span>

    <!-- Arrow animation -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      class="shrink-0 transition-transform duration-200 group-hover:translate-x-0.5"
    >
      <path d="M5 12h14M12 5l7 7-7 7"></path>
    </svg>
  </a>
</div>

<script>
  const btn = document.getElementById("float-cta");

  // Hide the button entirely when user is already on /contacto
  if (btn && window.location.pathname.startsWith("/contacto")) {
    btn.hidden = true;
  } else if (btn) {
    // Reveal the floating CTA only after the user scrolls past the hero,
    // so it doesn't compete with the hero's own "Solicitar presupuesto".
    const reveal = () => {
      const threshold = window.innerHeight * 0.6;
      const visible = window.scrollY > threshold;
      btn.classList.toggle("translate-y-24", !visible);
      btn.classList.toggle("opacity-0", !visible);
      btn.toggleAttribute("data-hidden", !visible);
    };

    reveal();
    window.addEventListener("scroll", reveal, { passive: true });
    window.addEventListener("resize", reveal, { passive: true });
  }
</script>
