---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import Button from "../../components/ui/Button.astro";
import Page from "../../layouts/Page.astro";
import { resolveDoc } from "../../lib/docs";
import { resolveImages } from "../../lib/images";
import { blogPostingSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const entries = await getCollection("blog");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"blog"> };
const { entry } = Astro.props;
const post = entry.data;
const imagenes = resolveImages(post.imagenes);
const { Content } = await render(entry);

const documentos = post.documentos.map((doc) => ({
  ...doc,
  url: resolveDoc(doc.archivo),
}));

const description = post.resumen.slice(0, 160);
const url = `/blog/${entry.id}`;
const schema = blogPostingSchema(
  {
    headline: post.titulo,
    description,
    articleBody: post.resumen,
    url,
    images: imagenes,
  },
  Astro.site,
);

const crumbs = [
  { label: "Inicio", href: "/" },
  { label: "Noticias", href: "/blog" },
  { label: post.titulo, href: url },
];
---

<Page
  title={`${post.titulo} | Noticias - Grúas del Vallès`}
  description={description}
  image={imagenes[0]}
  schema={schema}
>
  <article class="section-padding bg-surface">
    <div class="container-narrow">
      <Breadcrumb items={crumbs} class="mb-8" />

      <header class="mb-8 max-w-3xl">
        <p class="eyebrow"><span class="h-px w-8 bg-accent"></span>Noticia</p>
        <h1 class="text-3xl font-black leading-tight sm:text-4xl">
          {post.titulo}
        </h1>
      </header>

      {
        imagenes.length > 0 && (
          <div class="mb-8 grid gap-px bg-muted">
            <div class="aspect-video overflow-hidden bg-surface-alt">
              <img
                src={imagenes[0]}
                alt={post.titulo}
                class="h-full w-full cursor-zoom-in object-cover"
                data-zoomable
              />
            </div>
            {imagenes.length > 1 && (
              <div class="grid grid-cols-3 gap-px">
                {imagenes.slice(1).map((src) => (
                  <div class="aspect-video overflow-hidden bg-surface-alt">
                    <img
                      src={src}
                      alt={post.titulo}
                      class="h-full w-full cursor-zoom-in object-cover"
                      loading="lazy"
                      data-zoomable
                    />
                  </div>
                ))}
              </div>
            )}
          </div>
        )
      }

      <div
        class="blog-prose max-w-3xl text-base leading-relaxed text-ink-secondary"
      >
        <Content />
      </div>

      {
        documentos.length > 0 && (
          <section class="mt-10 max-w-3xl border-t border-muted pt-8">
            <h2 class="eyebrow">
              <span class="h-px w-8 bg-accent" />
              Documentación
            </h2>
            <ul class="mt-4 grid gap-px bg-muted">
              {documentos.map((doc) => (
                <li>
                  <a
                    href={doc.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-center gap-3 bg-surface px-4 py-3 transition-colors hover:bg-surface-alt"
                  >
                    <Icon
                      name="lucide:file-text"
                      class="h-5 w-5 shrink-0 text-accent"
                      aria-hidden="true"
                    />
                    <span class="flex-1 text-sm font-medium text-ink">
                      {doc.titulo}
                    </span>
                    <Icon
                      name="lucide:download"
                      class="h-4 w-4 shrink-0 text-muted-dark transition-colors group-hover:text-accent"
                      aria-hidden="true"
                    />
                  </a>
                </li>
              ))}
            </ul>
          </section>
        )
      }

      <div class="mt-8 flex flex-wrap gap-4">
        <Button href="/#contacto" icon="lucide:arrow-right"
          >Solicitar presupuesto</Button
        >
        <Button
          href="/blog"
          variant="outline"
          icon="lucide:arrow-left"
          iconPosition="start"
        >
          Ver todas las noticias
        </Button>
      </div>
    </div>
  </article>
</Page>

<style>
  /* Estilos del cuerpo Markdown de cada noticia. Usa los tokens del proyecto
     para mantener coherencia con el resto del sitio. */
  .blog-prose :global(p) {
    margin-block: 1rem;
  }
  .blog-prose :global(p:first-child) {
    margin-top: 0;
  }
  .blog-prose :global(h2),
  .blog-prose :global(h3) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-ink);
    font-weight: 700;
    line-height: 1.25;
  }
  .blog-prose :global(h2) {
    font-size: 1.5rem;
  }
  .blog-prose :global(h3) {
    font-size: 1.25rem;
  }
  .blog-prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-prose :global(strong) {
    color: var(--color-ink);
    font-weight: 600;
  }
  .blog-prose :global(ul),
  .blog-prose :global(ol) {
    margin-block: 1rem;
    padding-left: 1.5rem;
  }
  .blog-prose :global(ul) {
    list-style: disc;
  }
  .blog-prose :global(ol) {
    list-style: decimal;
  }
  .blog-prose :global(li) {
    margin-block: 0.375rem;
  }
  .blog-prose :global(blockquote) {
    margin-block: 1.25rem;
    border-left: 3px solid var(--color-accent);
    padding-left: 1rem;
    color: var(--color-ink-secondary);
    font-style: italic;
  }
  .blog-prose :global(img) {
    margin-block: 1.5rem;
    width: 100%;
  }
</style>
