---
import { Icon } from "astro-icon/components";
import creuRojaPdf from "../assets/docs/creu_roja.pdf";
import CtaBand from "../components/ui/CtaBand.astro";
import PageHero from "../components/ui/PageHero.astro";
import Page from "../layouts/Page.astro";

const organismos = [
  {
    icon: "lucide:building-2",
    nombre: "ANAGRUAL",
    nombre_completo:
      "Agrupación Empresarial Nacional de Alquiladores de Grúas de Servicio Público",
    descripcion:
      "Grúas del Vallès desempeña cargos en la Junta Directiva a nivel autonómico dentro de esta agrupación empresarial nacional.",
    enlace: "https://www.anagrual.es",
    pdf: null,
  },
  {
    icon: "lucide:truck",
    nombre: "TRANSCALIT",
    nombre_completo: "Federación Catalana de Transportes de Barcelona",
    descripcion:
      "Miembros de la Federación Catalana de Transportes, entidad de referencia en el sector del transporte en Cataluña.",
    enlace: null,
    pdf: null,
  },
  {
    icon: "lucide:heart-handshake",
    nombre: "CRUZ ROJA",
    nombre_completo: "Socio Colaborador desde 1997",
    descripcion:
      "Grúas del Vallès es socio colaborador de Cruz Roja desde 1997, comprometidos con la responsabilidad social y el apoyo a esta institución sin ánimo de lucro.",
    enlace: null,
    pdf: creuRojaPdf,
  },
];
---

<Page
  title="Organismos y Asociaciones | Grúas del Vallès"
  description="Grúas del Vallès pertenece a distintas asociaciones empresariales y organismos a nivel nacional y autonómico, además de entidades sin ánimo de lucro como Cruz Roja."
>
  <PageHero
    title="Organismos y asociaciones"
    lede="Grúas del Vallès pertenece a distintas asociaciones empresariales y organismos tanto a nivel nacional como autonómico y forma parte de otras asociaciones sin ánimo de lucro."
    crumbs={[{ label: "Inicio", href: "/" }, { label: "Organismos" }]}
  />

  <!-- Intro -->
  <section class="section-padding bg-surface">
    <div class="container-wide max-w-3xl">
      <p class="eyebrow">
        <span class="h-px w-8 bg-accent"></span>Nuestro compromiso sectorial
      </p>
      <h2 class="mb-6 text-2xl font-black sm:text-3xl">
        Miembros activos del sector y de la sociedad
      </h2>
      <p class="leading-relaxed text-ink-secondary">
        Puede conocer más sobre estas organizaciones pulsando sobre cada uno de
        los logos o accediendo a los enlaces indicados.
      </p>
    </div>
  </section>

  <!-- Organismos -->
  <section class="section-padding bg-surface-alt">
    <div class="container-wide">
      <div class="grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3">
        {
          organismos.map((o) => (
            <div class="flex flex-col gap-4 bg-surface p-6 sm:p-8">
              <Icon
                name={o.icon}
                class="h-8 w-8 text-accent"
                aria-hidden="true"
              />
              <div>
                <h3 class="text-lg font-bold">{o.nombre}</h3>
                <p class="mt-0.5 text-xs font-medium uppercase tracking-wider text-accent">
                  {o.nombre_completo}
                </p>
              </div>
              <p class="flex-1 text-sm leading-relaxed text-ink-secondary">
                {o.descripcion}
              </p>
              <div class="flex flex-col gap-2">
                {o.enlace && (
                  <a
                    href={o.enlace}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:underline"
                  >
                    <Icon
                      name="lucide:external-link"
                      class="h-4 w-4"
                      aria-hidden="true"
                    />
                    Ver web
                  </a>
                )}
                {o.pdf && (
                  <a
                    href={o.pdf}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:underline"
                  >
                    <Icon
                      name="lucide:download"
                      class="h-4 w-4"
                      aria-hidden="true"
                    />
                    Descargar documento acreditativo
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Page>
