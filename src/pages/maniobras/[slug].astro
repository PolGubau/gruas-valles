---
import { type CollectionEntry, getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import Button from "../../components/ui/Button.astro";
import Page from "../../layouts/Page.astro";

export async function getStaticPaths() {
  const entries = await getCollection("maniobras");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<"maniobras"> };
const { entry } = Astro.props;
const m = entry.data;

// Parámetros técnicos (clave → etiqueta + unidad). Escalable.
const PARAM_FIELDS: [keyof typeof m, string, string][] = [
  ["peso_carga_t", "Peso de la carga", " t"],
  ["contrapesos_t", "Contrapesos", " t"],
  ["radio_m", "Radio", " m"],
  ["altura_m", "Altura", " m"],
  ["pluma_m", "Pluma", " m"],
  ["plumin_m", "Plumín", " m"],
  ["plumin_fijo_m", "Plumín fijo", " m"],
  ["plumin_abatible_m", "Plumín abatible", " m"],
  ["plumin_arriostrado_m", "Plumín arriostrado", " m"],
];

const params = PARAM_FIELDS.flatMap(([key, label, unit]) => {
  const value = m[key];
  return value === undefined || value === null
    ? []
    : [{ label, value: `${value}${unit}` }];
});

const crumbs = [
  { label: "Inicio", href: "/" },
  { label: "Maniobras", href: "/maniobras" },
  { label: m.titulo, href: `/maniobras/${entry.id}` },
];
---

<Page
  title={`${m.titulo} | Maniobras - Grúas del Vallès`}
  description={m.descripcion.slice(0, 160)}
>
  <article class="section-padding bg-surface">
    <div class="container-wide">
      <Breadcrumb items={crumbs} class="mb-8" />

      <header class="mb-10 max-w-3xl">
        <p class="eyebrow"><span class="h-px w-8 bg-accent"></span>Caso real</p>
        <h1 class="text-3xl font-black leading-tight sm:text-4xl">
          {m.titulo}
        </h1>
      </header>

      <div class="grid gap-10 lg:grid-cols-[1fr_320px]">
        <!-- Contenido -->
        <div>
          {
            m.imagenes.length > 0 && (
              <div class="mb-8 grid gap-px bg-muted">
                <div class="aspect-video overflow-hidden bg-surface-alt">
                  <img
                    src={m.imagenes[0]}
                    alt={m.titulo}
                    class="h-full w-full cursor-zoom-in object-cover"
                    data-zoomable
                  />
                </div>
                {m.imagenes.length > 1 && (
                  <div class="grid grid-cols-3 gap-px">
                    {m.imagenes.slice(1).map((src) => (
                      <div class="aspect-video overflow-hidden bg-surface-alt">
                        <img
                          src={src}
                          alt={m.titulo}
                          class="h-full w-full cursor-zoom-in object-cover"
                          loading="lazy"
                          data-zoomable
                        />
                      </div>
                    ))}
                  </div>
                )}
              </div>
            )
          }

          <p class="text-base leading-relaxed text-ink-secondary">
            {m.descripcion}
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/#contacto" icon="lucide:arrow-right"
              >Solicitar una maniobra similar</Button
            >
            <Button
              href="/maniobras"
              variant="outline"
              icon="lucide:arrow-left"
              iconPosition="start"
            >
              Ver todas las maniobras
            </Button>
          </div>
        </div>

        <!-- Aside técnico -->
        <aside class="space-y-8">
          {
            params.length > 0 && (
              <div class="border border-muted p-6">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted-dark">
                  Parámetros técnicos
                </h2>
                <dl class="space-y-3">
                  {params.map((p) => (
                    <div class="flex items-baseline justify-between gap-4 border-b border-muted/60 pb-2">
                      <dt class="text-sm text-ink-secondary">{p.label}</dt>
                      <dd class="text-sm font-bold">{p.value}</dd>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }

          {
            m.gruas_utilizadas && m.gruas_utilizadas.length > 0 && (
              <div class="border border-muted p-6">
                <h2 class="mb-4 text-xs font-semibold uppercase tracking-wider text-muted-dark">
                  Grúas utilizadas
                </h2>
                <ul class="space-y-3">
                  {m.gruas_utilizadas.map((grua) => (
                    <li class="flex items-start gap-2 text-sm font-medium">
                      <Icon
                        name="lucide:construction"
                        width={16}
                        height={16}
                        class="mt-0.5 shrink-0 text-accent"
                        aria-hidden="true"
                      />
                      {grua}
                    </li>
                  ))}
                </ul>
              </div>
            )
          }
        </aside>
      </div>
    </div>
  </article>
</Page>
