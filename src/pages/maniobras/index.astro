---
import { getCollection } from "astro:content";
import Page from "../../layouts/Page.astro";
import Button from "../../components/ui/Button.astro";
import Breadcrumb from "../../components/ui/Breadcrumb.astro";
import ManiobraCard from "../../components/maniobras/ManiobraCard.astro";
import { collectionPageSchema } from "../../lib/schema";

const entries = await getCollection("maniobras");
const maniobras = entries
  .map((e) => ({ slug: e.id, ...e.data }))
  .sort((a, b) => a.orden - b.orden);

const description =
  "Casos reales de maniobras de elevación: grandes tonelajes, montajes complejos y trabajos de precisión ejecutados con nuestra flota propia.";
const schema = collectionPageSchema(
  {
    name: "Maniobras realizadas",
    description,
    url: "/maniobras",
    items: maniobras.map((m) => ({
      name: m.titulo,
      url: `/maniobras/${m.slug}`,
    })),
  },
  Astro.site,
);

const crumbs = [
  { label: "Inicio", href: "/" },
  { label: "Maniobras", href: "/maniobras" },
];
---

<Page
  title="Maniobras realizadas | Grúas del Vallès"
  description={description}
  schema={schema}
>
  <section class="section-padding bg-surface-alt">
    <div class="container-wide">
      <Breadcrumb items={crumbs} class="mb-8" />

      <header class="mb-12 max-w-2xl">
        <p class="eyebrow">
          <span class="h-px w-8 bg-accent"></span>Casos reales
        </p>
        <h1 class="text-3xl font-black leading-tight sm:text-4xl">
          Maniobras que definen nuestra capacidad
        </h1>
        <p class="mt-4 text-sm leading-relaxed text-ink-secondary">
          Cada trabajo es un reto técnico distinto. Estos son algunos de los
          proyectos que mejor reflejan la precisión y potencia de nuestra flota.
        </p>
      </header>

      <!-- Grid -->
      <div class="grid gap-px bg-muted sm:grid-cols-2 lg:grid-cols-3">
        {maniobras.map((m) => <ManiobraCard maniobra={m} />)}
      </div>

      <!-- CTA -->
      <div class="mt-12 text-center">
        <Button href="/#contacto" icon="lucide:arrow-right">
          Solicitar una maniobra
        </Button>
      </div>
    </div>
  </section>
</Page>
